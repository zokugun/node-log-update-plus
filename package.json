{
	"name": "@zokugun/log-update-plus",
	"description": "Update the terminal line in place. Ideal for progress bars, animations, and live-updating status",
	"version": "0.1.1",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/node-log-update-plus",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/node-log-update-plus.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/node-log-update-plus/discussions/categories/issue-triage"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./lib/esm/index.mjs",
			"require": "./lib/cjs/index.cjs"
		}
	},
	"main": "lib/cjs/index.cjs",
	"module": "lib/esm/index.mjs",
	"typesVersions": {
		"*": {
			".": [
				"./lib/cjs/index.d.cts"
			]
		}
	},
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run build:lib",
		"build:lib": "tsc-leda generate",
		"build:package": "tsc-leda update-package",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib .test .src",
		"compile:src": "tsc -p src",
		"compile:test": "tsc -p test",
		"lint": "xo",
		"lint:all": "fixpack && npm audit && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"prepack": "npm run build",
		"prepare": "husky; fixpack || true",
		"release": "release-it",
		"test": "vitest run --reporter tree",
		"test:coverage": "vitest run --reporter tree --coverage --coverage.reporter text",
		"test:ui": "vitest --ui --coverage",
		"test:watch": "vitest",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run",
		"update:deps": "taze",
		"watch:build": "tsc-watch -p src --onSuccess 'npm run build'",
		"watch:src": "tsc-watch -p src",
		"watch:test": "tsc-watch -p test"
	},
	"dependencies": {
		"ansi-escapes": "7.3.0",
		"cli-cursor": "5.0.0",
		"slice-ansi": "7.1.2",
		"strip-ansi": "7.2.0",
		"wrap-ansi": "9.0.2"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@types/node": "20.19.39",
		"@vitest/coverage-v8": "4.1.3",
		"@vitest/ui": "4.1.3",
		"@zokugun/fs-extra-plus": "0.3.7",
		"@zokugun/tsc-leda": "0.3.1",
		"fixpack": "4.0.0",
		"globby": "16.2.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.0.0-1",
		"taze": "19.11.0",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"vitest": "4.1.3",
		"xo": "0.60.0"
	},
	"keywords": []
}
